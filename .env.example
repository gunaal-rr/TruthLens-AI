# TruthLens AI — Environment Configuration

# Application
APP_NAME=TruthLens AI
APP_VERSION=2.0.0
DEBUG=false

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Security
API_KEY=your-secret-api-key-here
API_KEY_ENABLED=false

# Logging
LOG_LEVEL=INFO

# Cache
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# Rate Limiter Backend: "memory" or "redis"
RATE_LIMITER_BACKEND=memory

# Redis (for future use)
REDIS_URL=redis://localhost:6379/0

# Evidence Fetching
SERPAPI_KEY=
EVIDENCE_CACHE_TTL=600
EVIDENCE_FETCH_TIMEOUT=5

# Gemini LLM (for AI-powered evidence classification)
GEMINI_API_KEY=
GEMINI_ENABLED=true
